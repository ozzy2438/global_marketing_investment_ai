# =============================================================
# JARVIS AI Agency OS — Environment Variables Template
# =============================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your actual values
# 3. Never commit .env to git!
# =============================================================

# ------ REQUIRED -----------------------------------------------

# SerpApi API Token — for Google Maps / business scanning
# Get it at: https://serpapi.com/
SERPAPI_API_KEY=your_serpapi_key_here

# ------ AI PROVIDERS (at least one recommended) ----------------
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic — Claude Code MCP integration + AI commands
CLAUDE_API_KEY=your_anthropic_api_key_here

# OpenAI — alternative AI provider (optional)
OPENAI_API_KEY=your_openai_api_key_here

# ------ DATABASE -----------------------------------------------

# SQLite (default — zero config, file auto-created)
DATABASE_URL=sqlite:///jarvis.db

# PostgreSQL (production — uncomment and fill if using Postgres)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/jarvis

# ------ SERVER -------------------------------------------------

# Port the FastAPI server listens on
PORT=8000

# Secret key for JWT / session signing (generate a strong random string)
SECRET_KEY=change-this-to-a-long-random-secret-key

# Environment: development | production
JARVIS_ENV=development

# ------ OUTREACH INTEGRATIONS (future/optional) ----------------

# Email (SMTP) — for automated cold outreach
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password

# Telegram Bot — for remote agency management via Telegram
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# ------ MISC ---------------------------------------------------

# Agency name shown in contracts and pitch scripts
AGENCY_NAME=My AI Agency
